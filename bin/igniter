#!/usr/bin/env bash
# igniter — the Igniter control-center front door (thin dispatcher over the package-local binaries).
#
# Taxonomy decided by LAB-DISTRIBUTION-CONTROL-CENTER-READINESS-P6; this v0 SKELETON
# (LAB-DISTRIBUTION-CONTROL-CENTER-CLI-SKELETON-P7) wires the verbs with HONEST delegation and narrow
# assembly commands. It adds NO authority of its own: loopback-only bind, the public-bind refusal, the request
# bound, package trust and host-config all stay in the owners (igweb-serve / igc / igniter-machine). The
# dispatcher only routes and hides the binary name / build path / target-dir plumbing.
#
#   igniter serve <app_dir> ...   → igweb-serve            (live; P2-compatible)
#   igniter check <app_dir>       → igweb-serve check      (live; dry build, no socket)
#   igniter doctor                → local non-mutating environment report (live)
#   igniter toolchain list        → report the v0 tool fleet present in the repo (live)
#   igniter toolchain install|update → bin/igniter-install  (live; local-source build+stage only — P11)
#   igniter package <lock|verify|verify-archive|graph|pack|admit>  → igc  (live; argv routing only — P12)
#   igniter app bundle ...        → assemble a host-run app bundle (live; assembly only — P14)
#   igniter agent                 → local stdio MCP surface for agents (live; tools shell-delegate here — P24)
#   igniter env <doctor|template|check> → operator env-name catalogue from host.example.toml (live; names-only — P33/P34)
#
# No root workspace, no installer, no registry/download, no systemd/Docker/Homebrew. Point
# IGNITER_IGWEB_SERVE_BIN at a prebuilt igweb-serve (e.g. a release-bundle path) to skip building.
set -euo pipefail

PROG="igniter"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
WEB_CRATE="$REPO_ROOT/server/igniter-web"
# Build-time prerequisite: the compiler `include_str!`s this from the canon sibling repo (verified by doctor).
LANG_SIBLING="$REPO_ROOT/../igniter-lang"
LANG_INVENTORY="$LANG_SIBLING/docs/spec/stdlib-inventory.json"
# P11: `toolchain install|update` delegate to the co-located bootstrap installer (a sibling of this script
# in a SOURCE checkout's bin/). A STAGED prefix has only the front door, so $INSTALLER is absent there.
INSTALLER="$SCRIPT_DIR/igniter-install"
# Mirrors bin/igniter-install's default prefix. The REAL default stays single-sourced in the installer
# (we invoke it WITHOUT --prefix when the user gives none); this copy is used only for the `update`
# precondition check below.
DEFAULT_PREFIX="${HOME}/.igniter"

usage() {
  cat <<'EOF'
usage: igniter <command> [args]

The Igniter control center — one front door that delegates to the package-local tools.

App lifecycle:
  serve <app_dir> [--addr 127.0.0.1:PORT] [--max-requests N] [--host-config PATH]
                        build + serve a local IgWeb app on loopback (→ igweb-serve)
  serve --check <app_dir> | check <app_dir>
                        dry build/verify the app and exit; opens NO socket (→ igweb-serve check)

Diagnostics & toolchain:
  doctor                local, non-mutating environment report (binaries, repo, igniter-lang sibling, rustc)
  toolchain list        show the v0 tool fleet and whether each binary is built in the repo
  toolchain install [--prefix PATH]   build+stage the fleet from THIS checkout (→ bin/igniter-install)
  toolchain update  [--prefix PATH]   rebuild+restage an already-installed prefix (local-source only)

Packaging & deployment:
  package <sub> [args]  delegate to `igc`, the package authority (argv routing only — NOT a second
                        resolver): lock | verify | verify-archive | graph | pack | admit
  app bundle <app_dir> --out <dir> --version <stamp>
                        assemble a versioned, runnable app bundle (assembly only — host owns systemd/bind/
                        TLS/DB/secrets); see 'igniter app --help'

Agent control plane:
  agent                 start the local stdio MCP surface for agents (Codex/Claude/IDE) — SAFE, non-mutating
                        tools that delegate to this front door (doctor/toolchain_list/check_app/package_verify)

Operator environment:
  env doctor <app|bundle>     report required machine-mode env vars + set/unset/empty (values NEVER printed)
  env template <app|bundle>   print a blank `export NAME=` skeleton (no .env read, no injection)
  env check <app|bundle>      GATE: exit non-zero if a required env var is unset/empty

Stdlib help (delegate to igc; JSON is the stable agent contract — routing only, no second docs authority):
  stdlib list [--category C] [--json]   list the implemented stdlib surface (→ igc stdlib list)
  stdlib search QUERY... [--json]       ranked substring search over the surface (→ igc stdlib search)
  stdlib show NAME_OR_ALIAS [--json]    show one entry by canonical name or alias (→ igc stdlib show)
  explain RULE [--json]                 link a diagnostic (e.g. OOF-COL3) back to stdlib entries (→ igc explain)

  -h | --help           this help

Safety: every verb routes to a named owner that enforces its authority — loopback/public-bind refusal and
the request bound live in igweb-serve; package trust + STDLIB_VERSION in igc; host authority in --host-config.
This dispatcher grants nothing new. Env: IGNITER_IGWEB_SERVE_BIN=/path/to/igweb-serve.
EOF
}

# Serve-specific help (shown by `igniter serve --help`) — keeps the P2 contract detail discoverable.
serve_usage() {
  cat <<'EOF'
usage: igniter serve <app_dir> [--addr 127.0.0.1:PORT] [--max-requests N] [--host-config PATH]
       igniter serve --check <app_dir>
       igniter serve --help

Start a local IgWeb app, Rails-`s` style. Thin wrapper over `igweb-serve` (server/igniter-web).

  serve <app_dir>      build the app and serve it on loopback (default 127.0.0.1:0 — an OS-chosen port)
  --check <app_dir>    dry build/verify the app and exit; opens NO socket
  --addr HOST:PORT     loopback-only bind address (igweb-serve REFUSES a non-loopback address)
  --max-requests N     bound the run to N requests (the runner is intentionally bounded, not a daemon)
  --host-config PATH   host.toml for machine-mode (needs igweb-serve built with --features machine)

Safety (enforced by igweb-serve, not this wrapper): loopback-only, request-bounded, no public bind,
no implicit DB/DSN, no inline secrets, no daemon. Host authority stays explicit via --host-config.

Env: IGNITER_IGWEB_SERVE_BIN=/path/to/igweb-serve  # use a prebuilt binary instead of building.
EOF
}

# ── binary resolution ──────────────────────────────────────────────────────────────────────────────

# Resolve the igweb-serve binary:
#   explicit override → co-located (staged prefix: a sibling next to this script) → repo target → build.
# The co-located case is what a bootstrap install (LAB-DISTRIBUTION-BOOTSTRAP-INSTALL-P8) relies on:
# `<prefix>/bin/{igniter,igweb-serve,…}` is self-contained and never rebuilds from a source checkout.
resolve_igweb_serve() {
  if [[ -n "${IGNITER_IGWEB_SERVE_BIN:-}" ]]; then
    printf '%s' "$IGNITER_IGWEB_SERVE_BIN"; return 0
  fi
  if [[ -x "$SCRIPT_DIR/igweb-serve" ]]; then printf '%s' "$SCRIPT_DIR/igweb-serve"; return 0; fi
  local cand
  for cand in "$WEB_CRATE/target/release/igweb-serve" "$WEB_CRATE/target/debug/igweb-serve"; do
    if [[ -x "$cand" ]]; then printf '%s' "$cand"; return 0; fi
  done
  echo "$PROG: building igweb-serve (first run; this is hidden plumbing)…" >&2
  ( cd "$WEB_CRATE" && cargo build --release --bin igweb-serve ) >&2
  printf '%s' "$WEB_CRATE/target/release/igweb-serve"
}

# Resolve the igniter-agent MCP binary (P24): override → co-located staged → repo target → build.
resolve_agent() {
  if [[ -n "${IGNITER_AGENT_BIN:-}" ]]; then printf '%s' "$IGNITER_AGENT_BIN"; return 0; fi
  if [[ -x "$SCRIPT_DIR/igniter-agent" ]]; then printf '%s' "$SCRIPT_DIR/igniter-agent"; return 0; fi
  local cand
  for cand in "$WEB_CRATE/target/release/igniter-agent" "$WEB_CRATE/target/debug/igniter-agent"; do
    if [[ -x "$cand" ]]; then printf '%s' "$cand"; return 0; fi
  done
  echo "$PROG: building igniter-agent (first run; this is hidden plumbing)…" >&2
  ( cd "$WEB_CRATE" && cargo build --release --bin igniter-agent ) >&2
  printf '%s' "$WEB_CRATE/target/release/igniter-agent"
}

# Resolve the igc (package authority) binary, mirroring resolve_igweb_serve's order MINUS the auto-build:
#   explicit override → co-located staged (P8: <prefix>/bin/igc) → repo target (igniter_compiler) → fail.
# We do NOT auto-build igc here: a `package` verb must never silently kick off a compiler build (which also
# needs the igniter-lang sibling). Missing igc fails closed with a build/install suggestion (see cmd_package).
# NOTE: the staged name is `igc` but the cargo artifact is `igniter_compiler` (the P1/P3 name caveat).
resolve_igc() {
  if [[ -n "${IGNITER_IGC_BIN:-}" ]]; then printf '%s' "$IGNITER_IGC_BIN"; return 0; fi
  if [[ -x "$SCRIPT_DIR/igc" ]]; then printf '%s' "$SCRIPT_DIR/igc"; return 0; fi
  local p
  if p="$(probe_built igniter-compiler igniter_compiler)"; then printf '%s' "$p"; return 0; fi
  return 1
}

# Echo the path to an already-built binary (release preferred, then debug); return 1 if not present.
#   $1 = crate dir relative to REPO_ROOT   $2 = built artifact filename
probe_built() {
  local d p
  for d in release debug; do
    p="$REPO_ROOT/$1/target/$d/$2"
    if [[ -x "$p" ]]; then printf '%s' "$p"; return 0; fi
  done
  return 1
}

# ── small provenance helpers (used by `app bundle`) ──────────────────────────────────────────────────

# sha256 hex of a file (macOS `shasum` or GNU `sha256sum`); prints "unavailable" if neither exists.
sha256_of() {
  if command -v shasum >/dev/null 2>&1; then shasum -a 256 "$1" | awk '{print $1}'
  elif command -v sha256sum >/dev/null 2>&1; then sha256sum "$1" | awk '{print $1}'
  else printf 'unavailable'; fi
}

# Host target triple via rustc, or "unknown".
host_triple() {
  local t; t="$(rustc -vV 2>/dev/null | sed -n 's/^host: //p' | head -1)"
  printf '%s' "${t:-unknown}"
}

# Read a quoted TOML string value: toml_str FILE SECTION KEY (no nesting; good enough for igweb.toml).
toml_str() {
  awk -v sec="$2" -v key="$3" '
    /^[[:space:]]*\[/ { cur=$0; gsub(/[][[:space:]]/,"",cur); next }
    {
      line=$0
      if (line ~ ("^[[:space:]]*" key "[[:space:]]*=") && cur==sec) {
        sub(/^[^=]*=[[:space:]]*/,"",line); gsub(/^"|"[[:space:]]*$/,"",line); print line; exit
      }
    }' "$1"
}

# ── manifest.json readers (P35 admit) — the manifest is emitted by THIS tool with a stable shape, so a
# narrow grep/sed parse is sufficient (and keeps `admit` free of a JSON dependency). ───────────────────
# String value of a `"key": "value"` field. `"app"` won't match inside `"app_sources"` (closing quote).
mjson_str() {
  grep -oE "\"$2\"[[:space:]]*:[[:space:]]*\"[^\"]*\"" "$1" | head -1 | sed -E 's/.*:[[:space:]]*"([^"]*)"/\1/'
}
# Bare boolean value of a `"key": true|false` field.
mjson_bool() {
  grep -oE "\"$2\"[[:space:]]*:[[:space:]]*(true|false)" "$1" | head -1 | sed -E 's/.*:[[:space:]]*//'
}
# The runner sha256 lives on its OWN indented line (`    "sha256": "…"`); app_sources shas are inline in the
# `"app_sources": […]` array line, so anchoring to a leading-whitespace `"sha256"` isolates the runner one.
mjson_runner_sha() {
  grep -E '^[[:space:]]*"sha256"[[:space:]]*:' "$1" | head -1 | sed -E 's/.*"sha256"[[:space:]]*:[[:space:]]*"([^"]*)".*/\1/'
}

# ── verbs: live ─────────────────────────────────────────────────────────────────────────────────────

cmd_serve() {
  if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then serve_usage; exit 0; fi
  local bin; bin="$(resolve_igweb_serve)"
  if [[ ! -x "$bin" ]]; then
    echo "$PROG: igweb-serve not found or not executable at: $bin" >&2; exit 1
  fi
  # `serve --check <app_dir>` → `igweb-serve check <app_dir>`; otherwise pass through (igweb-serve owns
  # parsing, defaults, and the loopback/bounded semantics — unchanged from P2).
  if [[ "${1:-}" == "--check" ]]; then shift; exec "$bin" check "$@"; fi
  exec "$bin" "$@"
}

cmd_check() {
  if [[ "${1:-}" == "-h" || "${1:-}" == "--help" || $# -eq 0 ]]; then
    echo "usage: igniter check <app_dir>   # dry build/verify; opens no socket (→ igweb-serve check)"
    [[ $# -eq 0 ]] && exit 2 || exit 0
  fi
  local bin; bin="$(resolve_igweb_serve)"
  if [[ ! -x "$bin" ]]; then
    echo "$PROG: igweb-serve not found or not executable at: $bin" >&2; exit 1
  fi
  exec "$bin" check "$@"
}

# ── doctor (LAB-DISTRIBUTION-DOCTOR-IMPL-P10): local, non-mutating; text + --json; toolchain + app modes ──

DOC_RECORDS=()   # each: scope<TAB>check<TAB>severity<TAB>detail<TAB>suggest
doc_emit() { DOC_RECORDS+=("$1"$'\t'"$2"$'\t'"$3"$'\t'"$4"$'\t'"$5"); }
json_escape() { local s="$1"; s="${s//\\/\\\\}"; s="${s//\"/\\\"}"; printf '%s' "$s"; }

doc_render_text() {
  local last_scope="" r scope check sev detail suggest
  for r in "${DOC_RECORDS[@]}"; do
    IFS=$'\t' read -r scope check sev detail suggest <<<"$r"
    if [[ "$scope" != "$last_scope" ]]; then echo "  [$scope]"; last_scope="$scope"; fi
    printf "    [%-4s] %-22s %s\n" "$sev" "$check" "$detail"
    if [[ -n "$suggest" ]]; then printf "           → %s\n" "$suggest"; fi
  done
  return 0   # never let a falsy `[[ ]]` be the function's exit status (set -e would abort the caller)
}
doc_render_json() {
  local n=${#DOC_RECORDS[@]} i=0 r scope check sev detail suggest sfx sj
  echo "["
  for r in "${DOC_RECORDS[@]}"; do
    i=$((i+1)); sfx=","; [[ $i -eq $n ]] && sfx=""
    IFS=$'\t' read -r scope check sev detail suggest <<<"$r"
    if [[ -z "$suggest" ]]; then sj="null"; else sj="\"$(json_escape "$suggest")\""; fi
    printf '  {"scope": "%s", "check": "%s", "severity": "%s", "detail": "%s", "suggest": %s}%s\n' \
      "$scope" "$check" "$sev" "$(json_escape "$detail")" "$sj" "$sfx"
  done
  echo "]"
}

cmd_doctor() {
  # Local, non-mutating: no network, no DB, no build, no mutation, no secret values. v0 exits 0 (a report).
  local json=0 app_dir=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --json) json=1; shift ;;
      -h|--help) echo "usage: igniter doctor [<app_dir>] [--json]   # local, non-mutating; exits 0"; exit 0 ;;
      -*) echo "$PROG: doctor: unknown option '$1'" >&2; exit 2 ;;
      *) app_dir="$1"; shift ;;
    esac
  done
  DOC_RECORDS=()

  # mode: source-checkout (crate dirs present) vs installed-prefix (staged binaries, no crate tree)
  local mode
  if [[ -f "$REPO_ROOT/server/igniter-web/Cargo.toml" ]]; then mode="source-checkout"; else mode="installed-prefix"; fi
  doc_emit env mode info "$mode (root: $REPO_ROOT)" ""

  if command -v rustc >/dev/null 2>&1; then doc_emit env rustc ok "$(rustc --version 2>/dev/null)" ""
  else doc_emit env rustc fail "not found" "install Rust via https://rustup.rs (needed to build the tools)"; fi
  if command -v cargo >/dev/null 2>&1; then doc_emit env cargo ok "$(cargo --version 2>/dev/null)" ""
  else doc_emit env cargo fail "not found" "install the Rust toolchain"; fi

  # igniter-lang sibling — a BUILD prerequisite; only a failure when we are in a source checkout.
  if [[ "$mode" == "source-checkout" ]]; then
    if [[ -f "$LANG_INVENTORY" ]]; then doc_emit env "igniter-lang sibling" ok "$LANG_SIBLING (stdlib-inventory.json present)" ""
    else doc_emit env "igniter-lang sibling" fail "absent at $LANG_SIBLING" "check out igniter-lang beside igniter-lab to BUILD igc"; fi
  else
    doc_emit env "igniter-lang sibling" info "not required in installed-prefix mode (build-time only)" ""
  fi

  case ":$PATH:" in
    *":$SCRIPT_DIR:"*) doc_emit env PATH ok "$SCRIPT_DIR is on PATH" "" ;;
    *) doc_emit env PATH warn "$SCRIPT_DIR not on PATH" "export PATH=\"$SCRIPT_DIR:\$PATH\"" ;;
  esac

  if [[ -f "$REPO_ROOT/igniter-manifest.json" ]]; then
    doc_emit env manifest info "$REPO_ROOT/igniter-manifest.json present" ""
  elif [[ "$mode" == "installed-prefix" ]]; then
    doc_emit env manifest warn "no igniter-manifest.json in prefix" "re-run igniter-install to record provenance"
  fi

  # fleet: co-located staged ($SCRIPT_DIR/<name>) → IGNITER_IGWEB_SERVE_BIN (igweb-serve) → repo target
  local label crate artifact build path
  while IFS='|' read -r label crate artifact build; do
    [[ -z "$label" ]] && continue
    if [[ -x "$SCRIPT_DIR/$label" ]]; then doc_emit toolchain "$label" ok "$SCRIPT_DIR/$label (staged)" ""
    elif [[ "$label" == "igweb-serve" && -n "${IGNITER_IGWEB_SERVE_BIN:-}" && -x "${IGNITER_IGWEB_SERVE_BIN}" ]]; then
      doc_emit toolchain "$label" ok "$IGNITER_IGWEB_SERVE_BIN (env)" ""
    elif path="$(probe_built "$crate" "$artifact")"; then doc_emit toolchain "$label" ok "$path (repo build)" ""
    else doc_emit toolchain "$label" warn "not built" "igniter-install  (or: cd $crate && $build)"; fi
  done <<EOF
igc|igniter-compiler|igniter_compiler|cargo build --release
igniter-vm|igniter-vm|igniter-vm|cargo build --release --bin igniter-vm
igweb-serve|server/igniter-web|igweb-serve|cargo build --release --bin igweb-serve
igniter-mcp|igniter-machine|igniter-mcp|cargo build --release --bin igniter-mcp
tbackend|igniter-tbackend|tbackend|cargo build --release --bin tbackend
EOF
  # optional igniter-repl: ok/present when staged or built in repo target; else info/optional.
  local repl_doc_path
  if [[ -x "$SCRIPT_DIR/igniter-repl" ]]; then
    doc_emit toolchain igniter-repl ok "$SCRIPT_DIR/igniter-repl (optional, staged)" ""
  elif repl_doc_path="$(probe_built igniter-machine igniter-repl)"; then
    doc_emit toolchain igniter-repl ok "$repl_doc_path (optional, repo build)" ""
  else
    doc_emit toolchain igniter-repl info "optional — opt-in via 'install --with-repl' (or --features repl); not in the default v0 fleet (P17/P21)" ""
  fi

  # ── app-shape checks (only when <app_dir> is given) ──
  if [[ -n "$app_dir" ]]; then
    if [[ -d "$app_dir" ]]; then
      doc_emit app app-dir ok "$app_dir" ""
      if [[ -f "$app_dir/igweb.toml" ]]; then
        if grep -qE '^[[:space:]]*\[app\]' "$app_dir/igweb.toml" 2>/dev/null; then
          doc_emit app igweb.toml ok "present with [app]" "igniter check $app_dir  (verify it builds)"
        else
          doc_emit app igweb.toml warn "present but no [app] section" "add [app] entry = \"…\""
        fi
      else
        doc_emit app igweb.toml warn "no igweb.toml" "add an igweb.toml manifest ([app] entry=…)"
      fi
      if [[ -f "$app_dir/host.toml" ]]; then
        local bad="" k
        for k in dsn password secret token passport api_key; do
          if grep -qE "^[[:space:]]*$k[[:space:]]*=" "$app_dir/host.toml" 2>/dev/null \
             && ! grep -qE "^[[:space:]]*${k}_env[[:space:]]*=" "$app_dir/host.toml" 2>/dev/null; then
            bad="$bad $k"
          fi
        done
        if [[ -n "$bad" ]]; then
          doc_emit app host.toml fail "inline secret key(s):$bad" "use <key>_env = \"VAR_NAME\" (never inline values)"
        else
          doc_emit app host.toml ok "env-var references only (no inline secrets)" ""
        fi
        local name
        while IFS= read -r name; do
          [[ -z "$name" ]] && continue
          if [[ -n "${!name:-}" ]]; then doc_emit app "env:$name" ok "set" ""
          else doc_emit app "env:$name" warn "unset" "export $name=… before serving (value never read by doctor)"; fi
        done < <(grep -oE '[A-Za-z_][A-Za-z0-9_]*_env[[:space:]]*=[[:space:]]*"[^"]+"' "$app_dir/host.toml" 2>/dev/null \
                  | sed -E 's/.*"([^"]+)"/\1/')
      else
        doc_emit app host.toml info "no host.toml (observed/loopback default; machine-mode not configured)" ""
      fi
      doc_emit app build info "doctor does not compile" "run 'igniter check $app_dir' to build/verify the entry"
    else
      doc_emit app app-dir fail "not a directory: $app_dir" "check the path"
    fi
  fi

  # ── render ──
  if [[ "$json" -eq 1 ]]; then
    doc_render_json
  else
    echo "igniter doctor — local, non-mutating (v0 exits 0; severities: ok/warn/fail/info)"
    echo "  repo_root: $REPO_ROOT"
    doc_render_text
    echo "  next: 'igniter serve <app_dir>' to run; 'igniter check <app_dir>' to dry-build."
  fi
  exit 0   # v0: always a report (--strict deferred)
}

# Shared fleet report used by `doctor` and `toolchain list`. $1 = indent.
toolchain_report() {
  local indent="${1:-}"
  # rows: label | crate-dir (rel) | artifact | build command
  # NOTE: igniter_compiler self-names `igc`; artifact file is `igniter_compiler` (P1/P3 name caveat).
  local rows="igc|igniter-compiler|igniter_compiler|cargo build --release
igniter-vm|igniter-vm|igniter-vm|cargo build --release --bin igniter-vm
igweb-serve|server/igniter-web|igweb-serve|cargo build --release --bin igweb-serve
igniter-mcp|igniter-machine|igniter-mcp|cargo build --release --bin igniter-mcp
tbackend|igniter-tbackend|tbackend|cargo build --release --bin tbackend"
  local label crate artifact build path
  while IFS='|' read -r label crate artifact build; do
    [[ -z "$label" ]] && continue
    if [[ -x "$SCRIPT_DIR/$label" ]]; then
      echo "${indent}[present] $label → $SCRIPT_DIR/$label (staged)"
    elif [[ "$label" == "igweb-serve" && -n "${IGNITER_IGWEB_SERVE_BIN:-}" && -x "${IGNITER_IGWEB_SERVE_BIN}" ]]; then
      echo "${indent}[present] $label → $IGNITER_IGWEB_SERVE_BIN (IGNITER_IGWEB_SERVE_BIN)"
    elif path="$(probe_built "$crate" "$artifact")"; then
      echo "${indent}[present] $label → $path"
    else
      echo "${indent}[absent ] $label — build: (cd $crate && $build)"
    fi
  done <<EOF
$rows
EOF
  # igniter-repl is OPTIONAL (not a default fleet member). Show [present] if staged co-located or already
  # built in the repo target (e.g. after `install --with-repl` or a local --features repl build); else [optional].
  local repl_path
  if [[ -x "$SCRIPT_DIR/igniter-repl" ]]; then
    echo "${indent}[present] igniter-repl → $SCRIPT_DIR/igniter-repl (optional, staged)"
  elif repl_path="$(probe_built igniter-machine igniter-repl)"; then
    echo "${indent}[present] igniter-repl → $repl_path (optional, repo build)"
  else
    echo "${indent}[optional] igniter-repl — opt-in via 'install --with-repl' (or --features repl); not in the default v0 fleet (P17/P21)"
  fi
}

toolchain_usage() {
  cat <<EOF
usage: igniter toolchain <list | install | update> [--prefix PATH]

  list                       show the v0 tool fleet and whether each binary is built (live, non-mutating)
  install [--prefix PATH]    build the v0 fleet from THIS source checkout and stage it into PATH
  update  [--prefix PATH]    rebuild + restage into an already-installed PATH (requires a prior install)

install/update delegate to the repo-local bootstrap installer (bin/igniter-install). LOCAL SOURCE ONLY:
no remote download, no registry, no version solver, no signed artifacts, no Homebrew/Docker/tarball.
Default prefix is $DEFAULT_PREFIX (the installer's default). igniter-repl is optional (opt-in via
--features repl; not in the default v0 fleet; release build recovered — P17).
EOF
}

# Per-verb help for install/update (must state local-source-only and the no-remote/no-registry boundary).
toolchain_iu_usage() {
  local verb="$1" what
  if [[ "$verb" == install ]]; then
    what="Build the v0 binary fleet from THIS source checkout and stage it + the igniter front door into <PATH>/bin."
  else
    what="Rebuild + restage the v0 binary fleet into an ALREADY-INSTALLED <PATH> (requires a prior install)."
  fi
  cat <<EOF
usage: igniter toolchain $verb [--prefix PATH]

$what
Delegates to the repo-local bootstrap installer: $INSTALLER

LOCAL SOURCE ONLY — this compiles the 5 green binaries from the current igniter-lab checkout and copies
them into <PATH>/bin. There is NO remote download, NO registry, NO version solver, NO signed artifacts,
and NO Homebrew/Docker/tarball channel. igniter-repl is optional (opt-in via --with-repl; not in the
default v0 fleet; release build recovered — P17/P20).

  --prefix PATH   install root (binaries land in <PATH>/bin)   [default: $DEFAULT_PREFIX]
  --with-repl     also build+stage the optional igniter-repl (--features repl); NOT a default fleet member
  -h | --help     this help
EOF
  if [[ "$verb" == update ]]; then
    cat <<EOF

update requires an existing <PATH>/igniter-manifest.json (proof of a prior install); without it, update
fails and asks you to run 'igniter toolchain install' first. install and update otherwise perform the
same idempotent rebuild-and-restage.
EOF
  fi
}

cmd_toolchain() {
  local sub="${1:-}"
  case "$sub" in
    list)
      echo "igniter toolchain — v0 fleet (5 default binaries; igniter-repl optional, opt-in):"
      toolchain_report "  "
      exit 0 ;;
    install|update)
      shift
      cmd_toolchain_iu "$sub" "$@" ;;
    ""|-h|--help)
      toolchain_usage
      [[ "$sub" == "" ]] && exit 2 || exit 0 ;;
    *)
      echo "$PROG: unknown 'toolchain' subcommand '$sub' (try: list)" >&2; exit 2 ;;
  esac
}

# install/update delegate to the bootstrap installer. Both are the SAME local-source rebuild+restage;
# `update` only adds a precondition (an existing manifest at the target prefix). Delegation requires the
# installer co-located with this script — true in a SOURCE checkout (bin/igniter + bin/igniter-install),
# false in a STAGED prefix (which stages only the front door) → then fail clearly, source-required.
cmd_toolchain_iu() {
  local verb="$1"; shift
  local prefix="" with_repl=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help) toolchain_iu_usage "$verb"; exit 0 ;;
      --prefix) prefix="${2:?--prefix requires a PATH}"; shift 2 ;;
      --prefix=*) prefix="${1#--prefix=}"; shift ;;
      --with-repl) with_repl=1; shift ;;
      *) echo "$PROG: toolchain $verb: unknown argument '$1'" >&2; toolchain_iu_usage "$verb" >&2; exit 2 ;;
    esac
  done

  if [[ ! -x "$INSTALLER" ]]; then
    echo "$PROG: 'toolchain $verb' rebuilds from source, but the bootstrap installer is not co-located:" >&2
    echo "       not found at $INSTALLER" >&2
    echo "  → you appear to be running a STAGED igniter (only the front door is staged, not igniter-install)." >&2
    echo "    Re-run from an igniter-lab source checkout: (cd <checkout> && bin/igniter toolchain $verb${prefix:+ --prefix $prefix})" >&2
    exit 3
  fi

  if [[ "$verb" == "update" ]]; then
    local target="${prefix:-$DEFAULT_PREFIX}"
    if [[ ! -f "$target/igniter-manifest.json" ]]; then
      echo "$PROG: 'toolchain update' found no prior install at $target (missing igniter-manifest.json)." >&2
      echo "  → run 'igniter toolchain install${prefix:+ --prefix $prefix}' first; update only restages an existing prefix." >&2
      exit 3
    fi
  fi

  # Forward only the flags the user gave. No --prefix → the installer applies its own default (single
  # source of truth). --with-repl is passed through verbatim (opt-in; not a default fleet member).
  local -a inst_args=()
  [[ -n "$prefix" ]] && inst_args+=(--prefix "$prefix")
  [[ "$with_repl" == 1 ]] && inst_args+=(--with-repl)
  if [[ ${#inst_args[@]} -gt 0 ]]; then
    exec "$INSTALLER" "${inst_args[@]}"
  else
    exec "$INSTALLER"
  fi
}

# ── verbs: delegated packaging / app assembly (named owner, never silent success) ────────────────────

package_usage() {
  cat <<'EOF'
igniter package — a 1:1 argv alias to `igc`, the package authority. This is ROUTING ONLY: it invents NO
second resolver, lockfile format, package graph, registry, or trust model. All of that lives in `igc`.

  igniter package lock           [args]  → igc lock            (compute/refresh the workspace lock)
  igniter package verify         [args]  → igc verify          (WORKSPACE drift + assembly integrity)
  igniter package verify-archive [args]  → igc package verify  (a built .igpkg ARCHIVE)
  igniter package graph          [args]  → igc package graph
  igniter package pack           [args]  → igc package pack
  igniter package admit          [args]  → igc package admit

`verify` vs `verify-archive` is the one explicit disambiguation: bare `verify` is the workspace check
(`igc verify`); `.igpkg` archive verification is `verify-archive` (`igc package verify <file.igpkg>`).
All args after the subcommand and the exit code pass through unchanged. Env: IGNITER_IGC_BIN=/path/to/igc.
EOF
}

cmd_package() {
  if [[ "${1:-}" == "-h" || "${1:-}" == "--help" || $# -eq 0 ]]; then
    package_usage
    [[ $# -eq 0 ]] && exit 2 || exit 0
  fi
  local sub="$1"; shift
  # Map `igniter package <sub>` → the igc argv prefix. Routing only — no flag parsing/reinterpretation.
  local -a igc_args
  case "$sub" in
    lock)           igc_args=(lock) ;;
    verify)         igc_args=(verify) ;;
    verify-archive) igc_args=(package verify) ;;
    graph)          igc_args=(package graph) ;;
    pack)           igc_args=(package pack) ;;
    admit)          igc_args=(package admit) ;;
    *)
      echo "$PROG: unknown 'package' subcommand '$sub'" >&2
      echo "  supported (all → igc): lock | verify | verify-archive | graph | pack | admit" >&2
      echo "  see 'igniter package --help'" >&2
      exit 2 ;;
  esac
  local bin
  if ! bin="$(resolve_igc)" || [[ ! -x "$bin" ]]; then
    echo "$PROG: igc (the package authority) is not built/staged${bin:+ at: $bin}." >&2
    echo "  → build it:   (cd igniter-compiler && cargo build --release)   # → target/release/igniter_compiler" >&2
    echo "  → or install: bin/igniter-install                                    # stages a co-located 'igc'" >&2
    echo "  → or point:   IGNITER_IGC_BIN=/path/to/igc" >&2
    exit 1
  fi
  # exec preserves argv and the igc exit code verbatim.
  exec "$bin" "${igc_args[@]}" "$@"
}

# ── verbs: delegated stdlib help (LAB-IGNITER-CLI-CONTROL-CENTER-STDLIB-DELEGATION-P1) ────────────────
# DELEGATION ONLY: `igc` owns the stdlib surface + JSON contract + digest. This front door never parses
# stdlib-inventory.json, recomputes a digest, or becomes a second docs authority — it resolves `igc`,
# routes argv, and `exec`s so argv + exit code pass through verbatim (mirrors cmd_package).
stdlib_usage() {
  cat <<'EOF'
usage: igniter stdlib <list|search|show> ... [--json]
       igniter explain RULE [--json]

Query the implemented stdlib surface. ROUTING ONLY → delegates to `igc`; JSON output is the stable
agent contract (bin/igniter never parses stdlib-inventory.json or recomputes the digest).

  stdlib list [--category C] [--json]    → igc stdlib list      (kind: igniter_stdlib_list_result)
  stdlib search QUERY... [--json]        → igc stdlib search    (kind: igniter_stdlib_search_result)
  stdlib show NAME_OR_ALIAS [--json]     → igc stdlib show      (kind: igniter_stdlib_show_result)
  explain RULE [--json]                  → igc explain          (kind: igniter_diagnostic_explain_result)

Every result carries the current stdlib_surface_digest. Unknown `show` exits non-zero with
{"ok":false,"reason":"not_found"} — exactly because igc does. Env: IGNITER_IGC_BIN=/path/to/igc.
EOF
}

# Resolve igc and exec the given igc argv; fail closed with the same build/install/override hint as
# cmd_package. `$1` is a human label for the missing-binary message; the rest is the igc argv.
exec_igc_or_die() {
  local label="$1"; shift
  local bin
  if ! bin="$(resolve_igc)" || [[ ! -x "$bin" ]]; then
    echo "$PROG: igc (the $label authority) is not built/staged${bin:+ at: $bin}." >&2
    echo "  → build it:   (cd igniter-compiler && cargo build --release)   # → target/release/igniter_compiler" >&2
    echo "  → or install: bin/igniter-install                                    # stages a co-located 'igc'" >&2
    echo "  → or point:   IGNITER_IGC_BIN=/path/to/igc" >&2
    exit 1
  fi
  exec "$bin" "$@"
}

cmd_stdlib() {
  if [[ "${1:-}" == "-h" || "${1:-}" == "--help" || $# -eq 0 ]]; then
    stdlib_usage
    [[ $# -eq 0 ]] && exit 2 || exit 0
  fi
  # exec preserves the `igc stdlib <sub> …` argv and exit code verbatim.
  exec_igc_or_die "stdlib surface" stdlib "$@"
}

cmd_explain() {
  if [[ "${1:-}" == "-h" || "${1:-}" == "--help" || $# -eq 0 ]]; then
    stdlib_usage
    [[ $# -eq 0 ]] && exit 2 || exit 0
  fi
  exec_igc_or_die "diagnostic explain" explain "$@"
}

app_usage() {
  cat <<'EOF'
usage: igniter app bundle <app_dir> --out <dir> --version <stamp>

Assemble a versioned, self-contained IgWeb app bundle that a host/deploy layer can run (the home-lab
Model E shape). ASSEMBLY ONLY — this command never installs systemd, exposes a public listener, manages
TLS, creates a database, ships secrets, or mutates the host.

  <app_dir>         the IgWeb app directory (must contain igweb.toml; verified by `igweb-serve check`)
  --out <dir>       parent directory to write <appname>-<version>/ into
  --version <stamp> caller-supplied provenance stamp (there is NO clock in this tool — determinism/replay)

Emits  <out>/<appname>-<version>/:
  bin/igweb-serve                    copied runner, sha256-pinned in manifest.json
  app/<appname>/...                  author files (igweb.toml + routes.igweb + *.ig), copied verbatim + hashed
  run/run-<appname>.sh               loopback runner: igweb-serve --addr 127.0.0.1:$PORT --max-requests $N
  checks/check.sh                    re-runnable pre-start gate (runner -x, igweb.toml, `igweb-serve check`)
  systemd/<appname>.service.example  unit TEMPLATE — NEVER installed by Igniter (host owns enablement)
  host.toml.example                  only if the source app ships host.example.toml (env-NAMES only)
  manifest.json                      provenance (runner+source hashes, bind_policy, requires_machine)

Host-owned (OUTSIDE the bundle): systemd install/enable, the `current` symlink swap, public bind / reverse
proxy, TLS, DB creation/migration, secrets / DSNs / tokens / a real host.toml, and Docker. The bundle bakes
no bind authority — loopback refusal stays single-sourced in igweb-serve.

usage: igniter app admit <bundle_dir> --release-root <dir>

VALIDATE a bundle and COPY it into a release root. Admission is validate+place ONLY — it does NOT touch
`current`, install/restart systemd, expose a listener, create a DB, or ship secrets.

  <bundle_dir>        a directory produced by `igniter app bundle`
  --release-root DIR  copies the admitted release into <DIR>/releases/<app>/<version>/

Gates (all must pass; fail-closed, no partial release): manifest parses; bundle_format_version=="1";
bind_policy=="loopback"; public_release==false; bin/igweb-serve re-hash matches manifest; every app source
re-hash matches; checks/check.sh passes; no real host.toml; requires_machine ⇒ host.toml.example present;
destination must not already exist (no --force in v0). Activation (`current`), restart, and exposure stay
host-owned and are NOT performed.
EOF
}

# `igniter app bundle <app_dir> --out <dir> --version <stamp>` — assemble a bundle per P13. Fail-closed:
# every validation runs BEFORE the destination is created (or in a temp stage that is moved atomically), so
# a refused bundle never leaves a partial directory behind.
app_bundle() {
  local app_dir="" out="" version=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --out)     out="${2:-}"; shift 2 ;;
      --version) version="${2:-}"; shift 2 ;;
      -h|--help) app_usage; exit 0 ;;
      -*) echo "$PROG: app bundle: unknown option '$1'" >&2; exit 2 ;;
      *)  app_dir="$1"; shift ;;
    esac
  done
  # required-arg gates (fail closed; no clock → --version is mandatory)
  [[ -n "$app_dir" ]] || { echo "$PROG: app bundle: missing <app_dir>" >&2; app_usage >&2; exit 2; }
  [[ -d "$app_dir" ]] || { echo "$PROG: app bundle: no such app dir: $app_dir" >&2; exit 2; }
  [[ -n "$out" ]]     || { echo "$PROG: app bundle: --out <dir> is required" >&2; exit 2; }
  [[ -n "$version" ]] || { echo "$PROG: app bundle: --version <stamp> is required (no clock in this tool)" >&2; exit 2; }

  local manifest_toml="$app_dir/igweb.toml"
  [[ -f "$manifest_toml" ]] || { echo "$PROG: app bundle: $app_dir has no igweb.toml" >&2; exit 2; }

  # secret boundary: a real host.toml must never enter a bundle.
  if [[ -f "$app_dir/host.toml" ]]; then
    echo "$PROG: app bundle: refusing — $app_dir contains a real 'host.toml' (host-owned, may hold secrets)." >&2
    echo "  → keep only 'host.example.toml' (env-NAMES only) in the app dir; the real host.toml lives on the host." >&2
    exit 2
  fi

  local appname; appname="$(basename "$app_dir")"
  local app_env; app_env="$(printf '%s' "$appname" | tr '[:lower:]' '[:upper:]' | sed 's/[^A-Z0-9]/_/g')"

  # author-owned manifest fields + loopback gate
  local entry mode
  entry="$(toml_str "$manifest_toml" app entry)"
  [[ -n "$entry" ]] || { echo "$PROG: app bundle: igweb.toml [app] has no 'entry'" >&2; exit 2; }
  mode="$(toml_str "$manifest_toml" server mode)"
  if [[ -n "$mode" && "$mode" != "loopback" ]]; then
    echo "$PROG: app bundle: refusing — igweb.toml [server] mode='$mode' is not 'loopback' (public bind is host-owned)." >&2
    exit 2
  fi

  # optional operator example (env-NAMES only); refuse if it carries inline secret keys.
  local host_example=""
  if [[ -f "$app_dir/host.example.toml" ]]; then host_example="$app_dir/host.example.toml"
  elif [[ -f "$app_dir/host.toml.example" ]]; then host_example="$app_dir/host.toml.example"; fi
  if [[ -n "$host_example" ]]; then
    if grep -qiE '^[[:space:]]*(dsn|password|secret|token|passport|api_key)[[:space:]]*=' "$host_example"; then
      echo "$PROG: app bundle: refusing — '$host_example' has inline secret key(s) (env-NAMES only allowed):" >&2
      # report key + line, NEVER the value (sed strips everything after '=')
      grep -niE '^[[:space:]]*(dsn|password|secret|token|passport|api_key)[[:space:]]*=' "$host_example" \
        | sed -E 's/[[:space:]]*=.*/ =…(redacted)/' >&2
      exit 2
    fi
    local hmode; hmode="$(toml_str "$host_example" host mode)"
    if [[ -n "$hmode" && "$hmode" != "loopback" ]]; then
      echo "$PROG: app bundle: refusing — host example [host] mode='$hmode' is not 'loopback'." >&2
      exit 2
    fi
  fi
  local requires_machine="false"; [[ -n "$host_example" ]] && requires_machine="true"

  # the app must build/validate (no socket) BEFORE we assemble anything.
  local runner; runner="$(resolve_igweb_serve)"
  [[ -x "$runner" ]] || { echo "$PROG: app bundle: igweb-serve unavailable at: $runner" >&2; exit 1; }
  if ! "$runner" check "$app_dir" >/dev/null 2>&1; then
    echo "$PROG: app bundle: refusing — 'igweb-serve check $app_dir' failed (run 'igniter check $app_dir' to see why)." >&2
    exit 2
  fi

  local dest="$out/$appname-$version"
  [[ -e "$dest" ]] && { echo "$PROG: app bundle: destination already exists: $dest" >&2; exit 2; }

  # assemble in a temp stage; only an all-green stage is moved into place (no partial bundle on failure).
  local stage; stage="$(mktemp -d)"
  trap 'rm -rf "$stage"' EXIT
  mkdir -p "$stage/bin" "$stage/app/$appname" "$stage/run" "$stage/checks" "$stage/systemd"

  cp "$runner" "$stage/bin/igweb-serve"; chmod +x "$stage/bin/igweb-serve"

  # copy author files verbatim (igweb.toml + routes.igweb + *.ig + *.igweb); skip host configs (handled below)
  local f sources_json="" sep=""
  for f in "$app_dir"/igweb.toml "$app_dir"/*.igweb "$app_dir"/*.ig; do
    [[ -f "$f" ]] || continue
    cp "$f" "$stage/app/$appname/"
    local base; base="$(basename "$f")"
    sources_json="$sources_json$sep{\"path\":\"app/$appname/$base\",\"sha256\":\"$(sha256_of "$f")\"}"
    sep=","
  done
  [[ -n "$host_example" ]] && cp "$host_example" "$stage/host.toml.example"

  # emitted loopback runner script. Pure apps stay byte-compatible; machine-mode apps (host.toml.example
  # present) gain an explicit host-config precedence: env override → bundle host.toml → none.
  if [[ "$requires_machine" == true ]]; then
    cat > "$stage/run/run-$appname.sh" <<RUNEOF
#!/usr/bin/env bash
# loopback runner for '$appname' (emitted by 'igniter app bundle'). Public-bind refusal lives in igweb-serve.
# Machine-mode host-config precedence: IGNITER_${app_env}_HOST_CONFIG → bundle host.toml → none (template only).
# NOTE: --host-config needs an igweb-serve built with --features machine; secrets live in env vars the
# host.toml *references*, never in this script or the bundle.
set -euo pipefail
here="\$(cd "\$(dirname "\${BASH_SOURCE[0]}")/.." && pwd)"
PORT="\${IGNITER_${app_env}_PORT:-18080}"
MAX="\${IGNITER_${app_env}_MAX_REQUESTS:-1024}"
if [[ -n "\${IGNITER_${app_env}_HOST_CONFIG:-}" ]]; then
  exec "\$here/bin/igweb-serve" --addr "127.0.0.1:\${PORT}" --max-requests "\$MAX" --host-config "\${IGNITER_${app_env}_HOST_CONFIG}" "\$here/app/$appname"
elif [[ -f "\$here/host.toml" ]]; then
  exec "\$here/bin/igweb-serve" --addr "127.0.0.1:\${PORT}" --max-requests "\$MAX" --host-config "\$here/host.toml" "\$here/app/$appname"
else
  echo "run: machine-mode config not active (set IGNITER_${app_env}_HOST_CONFIG, or copy host.toml.example → host.toml). Serving observed/loopback only." >&2
  exec "\$here/bin/igweb-serve" --addr "127.0.0.1:\${PORT}" --max-requests "\$MAX" "\$here/app/$appname"
fi
RUNEOF
  else
    cat > "$stage/run/run-$appname.sh" <<RUNEOF
#!/usr/bin/env bash
# loopback runner for '$appname' (emitted by 'igniter app bundle'). Public-bind refusal lives in igweb-serve.
set -euo pipefail
here="\$(cd "\$(dirname "\${BASH_SOURCE[0]}")/.." && pwd)"
PORT="\${IGNITER_${app_env}_PORT:-18080}"
MAX="\${IGNITER_${app_env}_MAX_REQUESTS:-1024}"
exec "\$here/bin/igweb-serve" --addr "127.0.0.1:\${PORT}" --max-requests "\$MAX" "\$here/app/$appname"
RUNEOF
  fi
  chmod +x "$stage/run/run-$appname.sh"

  # emitted pre-start check (re-runs the bundle-time gate on the host). Opens NO socket / DB. For machine-mode
  # apps it also asserts host.toml.example is present, but never requires a real host.toml or any env vars.
  local mc_check=""
  if [[ "$requires_machine" == true ]]; then
    mc_check='[[ -f "$here/host.toml.example" ]] || { echo "check: host.toml.example missing (machine-mode app)"; exit 1; }'
  fi
  cat > "$stage/checks/check.sh" <<CHKEOF
#!/usr/bin/env bash
set -euo pipefail
here="\$(cd "\$(dirname "\${BASH_SOURCE[0]}")/.." && pwd)"
runner="\$here/bin/igweb-serve"; app="\$here/app/$appname"
[[ -x "\$runner" ]] || { echo "check: runner missing or not executable"; exit 1; }
[[ -f "\$app/igweb.toml" ]] || { echo "check: igweb.toml missing"; exit 1; }
$mc_check
"\$runner" check "\$app" >/dev/null
echo "check: ok ($appname)"
CHKEOF
  chmod +x "$stage/checks/check.sh"

  # emitted systemd unit TEMPLATE (never installed; operator edits ExecStart path + enables it). For
  # machine-mode apps it also shows the host-config env var NAME (value is host-owned; no secrets in the unit).
  local mc_unit_env=""
  if [[ "$requires_machine" == true ]]; then
    mc_unit_env="# Machine-mode: point HOST_CONFIG at the host-owned host.toml (copy host.toml.example → host.toml first).
# Secrets live in the env vars that host.toml *references* (DSN/token/passport), NOT in this unit.
Environment=IGNITER_${app_env}_HOST_CONFIG=%h/igniter-apps/$appname-$version/host.toml"
  fi
  cat > "$stage/systemd/$appname.service.example" <<UNITEOF
# TEMPLATE — not installed by Igniter. Copy to the host, set ExecStart to the deployed run script path,
# then 'systemctl --user enable --now'. Bind/exposure/TLS/secrets are host-owned.
[Unit]
Description=Igniter IgWeb app $appname (loopback)
After=network-online.target

[Service]
Type=simple
Environment=IGNITER_${app_env}_PORT=18080
Environment=IGNITER_${app_env}_MAX_REQUESTS=1024
$mc_unit_env
ExecStart=%h/igniter-apps/$appname-$version/run/run-$appname.sh
Restart=always
RestartSec=2

[Install]
WantedBy=default.target
UNITEOF

  # manifest.json (provenance; all non-secret). created_utc mirrors the caller stamp — no clock here.
  local runner_sha; runner_sha="$(sha256_of "$stage/bin/igweb-serve")"
  local triple; triple="$(host_triple)"
  local commit; commit="$(git -C "$REPO_ROOT" rev-parse --short HEAD 2>/dev/null || printf 'unknown')"
  cat > "$stage/manifest.json" <<MANEOF
{
  "bundle_format_version": "1",
  "tool": "igniter app bundle",
  "app": "$appname",
  "entry": "$entry",
  "version": "$version",
  "created_utc": "$version",
  "runner": {
    "path": "bin/igweb-serve",
    "sha256": "$runner_sha",
    "target_triple": "$triple",
    "source_git_commit": "$commit"
  },
  "app_sources": [$sources_json],
  "bind_policy": "loopback",
  "requires_machine": $requires_machine,
  "public_release": false
}
MANEOF

  # the emitted bundle must validate itself before we publish it.
  if ! bash "$stage/checks/check.sh" >/dev/null 2>&1; then
    echo "$PROG: app bundle: refusing — emitted checks/check.sh failed on the staged bundle." >&2
    exit 1
  fi

  mkdir -p "$out"
  mv "$stage" "$dest"
  trap - EXIT
  echo "$PROG: app bundle ok → $dest"
  echo "  runner sha256: $runner_sha   requires_machine: $requires_machine"
  echo "  next (host-owned): edit systemd/$appname.service.example ExecStart, then enable it; bind/TLS/secrets stay host-owned."
}

# `igniter app admit <bundle_dir> --release-root <dir>` (P35) — VALIDATE a bundle then COPY it into
# <release-root>/releases/<app>/<version>/. Admission is validate+place ONLY: it never touches `current`,
# systemd, network, secrets, or DBs. All gates run on the SOURCE before any staging, and the copy is staged
# within the release root and atomically renamed — a refusal leaves no partial release.
app_admit() {
  local bundle_dir="" release_root=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --release-root) release_root="${2:-}"; shift 2 ;;
      -h|--help) app_usage; exit 0 ;;
      -*) echo "$PROG: app admit: unknown option '$1'" >&2; exit 2 ;;
      *)  bundle_dir="$1"; shift ;;
    esac
  done
  [[ -n "$bundle_dir" ]] || { echo "$PROG: app admit: missing <bundle_dir>" >&2; app_usage >&2; exit 2; }
  [[ -d "$bundle_dir" ]] || { echo "$PROG: app admit: no such bundle dir: $bundle_dir" >&2; exit 2; }
  [[ -n "$release_root" ]] || { echo "$PROG: app admit: --release-root <dir> is required" >&2; exit 2; }

  local man="$bundle_dir/manifest.json"
  [[ -f "$man" ]] || { echo "$PROG: app admit: refusing — no manifest.json in $bundle_dir (gate 1)" >&2; exit 2; }

  # gate 1: manifest fields parse
  local app version bind_policy public_release fmt requires_machine runner_sha
  app="$(mjson_str "$man" app)"
  version="$(mjson_str "$man" version)"
  bind_policy="$(mjson_str "$man" bind_policy)"
  fmt="$(mjson_str "$man" bundle_format_version)"
  public_release="$(mjson_bool "$man" public_release)"
  requires_machine="$(mjson_bool "$man" requires_machine)"
  runner_sha="$(mjson_runner_sha "$man")"
  [[ -n "$app" && -n "$version" && -n "$runner_sha" ]] \
    || { echo "$PROG: app admit: refusing — manifest.json missing app/version/runner.sha256 (gate 1)" >&2; exit 2; }

  # gates 2-4: format + policy
  [[ "$fmt" == "1" ]] || { echo "$PROG: app admit: refusing — bundle_format_version='$fmt' != '1' (gate 2)" >&2; exit 2; }
  [[ "$bind_policy" == "loopback" ]] || { echo "$PROG: app admit: refusing — bind_policy='$bind_policy' != 'loopback' (gate 3)" >&2; exit 2; }
  [[ "$public_release" == "false" ]] || { echo "$PROG: app admit: refusing — public_release='$public_release' != false (gate 4)" >&2; exit 2; }

  # gate 5: re-hash the runner; must equal manifest.runner.sha256
  [[ -f "$bundle_dir/bin/igweb-serve" ]] || { echo "$PROG: app admit: refusing — bundle has no bin/igweb-serve (gate 5)" >&2; exit 2; }
  local actual_runner; actual_runner="$(sha256_of "$bundle_dir/bin/igweb-serve")"
  [[ "$actual_runner" == "$runner_sha" ]] \
    || { echo "$PROG: app admit: refusing — bin/igweb-serve sha256 mismatch (gate 5: tampered runner)" >&2; exit 2; }

  # gate 6: re-hash every app source; each must exist and match
  local pair p sha actual
  while IFS= read -r pair; do
    [[ -z "$pair" ]] && continue
    p="$(printf '%s' "$pair" | sed -E 's/.*"path":"([^"]*)".*/\1/')"
    sha="$(printf '%s' "$pair" | sed -E 's/.*"sha256":"([^"]*)".*/\1/')"
    [[ -f "$bundle_dir/$p" ]] || { echo "$PROG: app admit: refusing — app source missing: $p (gate 6)" >&2; exit 2; }
    actual="$(sha256_of "$bundle_dir/$p")"
    [[ "$actual" == "$sha" ]] || { echo "$PROG: app admit: refusing — app source sha256 mismatch: $p (gate 6: tampered source)" >&2; exit 2; }
  done < <(grep -oE '\{"path":"[^"]*","sha256":"[^"]*"\}' "$man")

  # gate 7: the bundle's own check.sh must pass (opens no socket/DB)
  [[ -f "$bundle_dir/checks/check.sh" ]] || { echo "$PROG: app admit: refusing — no checks/check.sh (gate 7)" >&2; exit 2; }
  if ! bash "$bundle_dir/checks/check.sh" >/dev/null 2>&1; then
    echo "$PROG: app admit: refusing — bundle checks/check.sh failed (gate 7)" >&2; exit 2
  fi

  # gate 8: a real host.toml must never be admitted
  if [[ -f "$bundle_dir/host.toml" ]]; then
    echo "$PROG: app admit: refusing — bundle contains a real 'host.toml' (gate 8: host-owned, may hold secrets)" >&2; exit 2
  fi
  # gate 9: machine-mode bundles must carry the commit-safe example
  if [[ "$requires_machine" == "true" && ! -f "$bundle_dir/host.toml.example" ]]; then
    echo "$PROG: app admit: refusing — requires_machine but no host.toml.example (gate 9)" >&2; exit 2
  fi

  # gate 10: never silently overwrite an admitted release (no --force in v0)
  local dest_parent="$release_root/releases/$app"
  local dest="$dest_parent/$version"
  [[ -e "$dest" ]] && { echo "$PROG: app admit: refusing — release already admitted at $dest (gate 10; no --force in v0)" >&2; exit 2; }

  # copy: stage WITHIN the release root (same filesystem → atomic rename); source is never moved/symlinked.
  mkdir -p "$dest_parent"
  local stage="$dest_parent/.admit-staging-$version-$$"
  rm -rf "$stage"
  trap 'rm -rf "$stage"' EXIT
  mkdir -p "$stage"
  cp -R "$bundle_dir"/. "$stage"/
  mv "$stage" "$dest"
  trap - EXIT

  echo "$PROG: app admit ok"
  echo "  app:              $app"
  echo "  version:          $version"
  echo "  admitted_path:    $dest"
  echo "  runner_sha256:    $runner_sha"
  echo "  requires_machine: $requires_machine"
  echo "  next (host-owned): activation/current/service restart are NOT performed by admit."
}

cmd_app() {
  local sub="${1:-}"
  case "$sub" in
    ""|-h|--help) app_usage; [[ "$sub" == "" ]] && exit 2 || exit 0 ;;
    bundle) shift; app_bundle "$@" ;;
    admit)  shift; app_admit "$@" ;;
    *)
      echo "$PROG: unknown 'app' subcommand '$sub' (try: bundle | admit)" >&2
      echo "  see 'igniter app --help'" >&2
      exit 2 ;;
  esac
}

agent_usage() {
  cat <<'EOF'
usage: igniter agent

Start the command-center MCP surface: a LOCAL stdio JSON-RPC server (MCP: initialize / tools/list /
tools/call) for agents (Codex/Claude/IDE). Its tools are SAFE and non-mutating — each delegates to this
same `igniter` front door, so it grants NOTHING beyond the verbs a human already runs.

v0 tools:
  doctor          → igniter doctor [app_dir] [--json]   (local report; no build, no socket)
  toolchain_list  → igniter toolchain list
  check_app       → igniter check <app_dir>             (dry build/verify; opens NO socket)
  package_verify  → igniter package verify              (→ igc verify; argv routing only)
  app_bundle      → igniter app bundle <app> --out <dir> --version <v>   (assembly only; bundler owns all
                    safety — host.toml/secret refusal, atomic staging; no deploy/systemd/public-bind)
  env_doctor      → igniter env doctor <path>           (required env NAMES + set/unset/empty; values never)
  env_check       → igniter env check <path>            (GATE: isError if a required env var is unset/empty)
  serve_app_bounded → igniter serve --addr 127.0.0.1:0 --max-requests N  (loopback + bounded ≤5; one GET;
                    waits for clean exit — NOT a daemon: no public bind, no background handle, no restart)

The agent itself opens no listener and speaks over stdin/stdout. The bounded serve tool may launch only a
loopback child with max requests; no public bind, deploy, systemd, secrets, or process supervisor. Wire it
into your agent's MCP server config. Env: IGNITER_AGENT_BIN=/path/to/igniter-agent.
EOF
}

# `igniter agent` — launch the command-center MCP server (P24). It shells back to THIS front door, so we pass
# our own absolute path as IGNITER_BIN; the agent grants no authority beyond these verbs.
cmd_agent() {
  if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then agent_usage; exit 0; fi
  if [[ $# -gt 0 ]]; then
    echo "$PROG: 'agent' takes no arguments (it speaks MCP over stdio). See 'igniter agent --help'." >&2
    exit 2
  fi
  local bin; bin="$(resolve_agent)"
  if [[ ! -x "$bin" ]]; then
    echo "$PROG: igniter-agent not found or not executable at: $bin" >&2; exit 1
  fi
  exec env IGNITER_BIN="$SCRIPT_DIR/igniter" "$bin"
}

# ── env (operator environment catalogue — P33) ───────────────────────────────────────────────────────

env_usage() {
  cat <<'EOF'
usage: igniter env doctor   <app_or_bundle>
       igniter env template <app_or_bundle>
       igniter env check    <app_or_bundle>

Report the machine-mode environment a host needs, from the COMMIT-SAFE env-name catalogue:
  app dir   → host.example.toml
  bundle    → host.toml.example
The real host.toml is operator-owned and is NEVER required (or read) here.

  doctor    list each required env var and whether it is set/unset/empty in THIS process (values NEVER printed)
  template  print a blank `export NAME=` skeleton for the operator to fill (current values are NOT shown)
  check     GATE: exit non-zero if any required env var is unset/empty (or the catalogue is invalid)

Secret-safe: env var NAMES only. Values are never read or printed — only set/unset/empty status.
A `.env` file is NOT read in v0. No injection, no deploy, no real host.toml.
EOF
}

# Emit `section|key|NAME` for every `*_env = "NAME"` in the catalogue file (stable file order).
env_catalogue() {
  awk '
    /^[[:space:]]*\[/ { sec=$0; gsub(/[][[:space:]]/,"",sec); next }
    /^[[:space:]]*[A-Za-z_][A-Za-z0-9_]*_env[[:space:]]*=/ {
      line=$0
      key=line; sub(/[[:space:]]*=.*/,"",key); gsub(/[[:space:]]/,"",key)
      val=line; sub(/^[^=]*=[[:space:]]*/,"",val); gsub(/^"|"[[:space:]]*$|[[:space:]]*$/,"",val)
      print sec "|" key "|" val
    }
  ' "$1"
}

cmd_env() {
  local verb="${1:-}"; shift || true
  case "$verb" in
    -h|--help|"") env_usage; [[ "$verb" == "" ]] && exit 2 || exit 0 ;;
    doctor|template|check) : ;;
    *) echo "$PROG: unknown 'env' subcommand '$verb' (try: doctor | template | check)" >&2; exit 2 ;;
  esac

  local target="${1:-}"
  [[ -n "$target" ]] || { echo "$PROG: env $verb: missing <app_or_bundle>" >&2; env_usage >&2; exit 2; }
  [[ -d "$target" ]] || { echo "$PROG: env $verb: not a directory: $target" >&2; exit 2; }

  # catalogue resolution: app `host.example.toml` → bundle `host.toml.example` → none
  local cat=""
  if [[ -f "$target/host.example.toml" ]]; then cat="$target/host.example.toml"
  elif [[ -f "$target/host.toml.example" ]]; then cat="$target/host.toml.example"; fi

  if [[ -z "$cat" ]]; then
    echo "igniter env $verb: no machine-mode env required (no host.example.toml / host.toml.example in $target)"
    exit 0
  fi

  # extract + validate names (reject empty + template syntax); dedup by NAME in stable order
  local -a seen=() rows=()
  local row sec key name
  while IFS='|' read -r sec key name; do
    [[ -z "$key" ]] && continue
    if [[ -z "$name" ]]; then
      echo "$PROG: env $verb: empty env-name for '$key' in $cat (expected $key = \"VAR_NAME\")" >&2; exit 2
    fi
    case "$name" in
      *'$'*|*'{{'*|*'}}'*) echo "$PROG: env $verb: template syntax in env-name '$name' ($key) is not supported" >&2; exit 2 ;;
    esac
    # dedup by NAME (keep first context)
    local dup=0 s
    for s in ${seen[@]+"${seen[@]}"}; do [[ "$s" == "$name" ]] && { dup=1; break; }; done
    [[ "$dup" == 1 ]] && continue
    seen+=("$name"); rows+=("$sec|$key|$name")
  done < <(env_catalogue "$cat")

  if [[ "${#rows[@]}" -eq 0 ]]; then
    echo "igniter env $verb: no env-name references (*_env) in $cat"
    exit 0
  fi

  if [[ "$verb" == "template" ]]; then
    echo "# blank export skeleton from $cat — fill values in your shell/host, never commit them"
    for row in "${rows[@]}"; do
      IFS='|' read -r sec key name <<<"$row"
      echo "export $name=   # ${sec:+[$sec].}$key"
    done
    exit 0
  fi

  # doctor + check share the status scan: set / unset / empty, never the value. doctor is a report (exit 0);
  # check is a GATE (exit non-zero if any required var is unset/empty).
  local header missing=0
  if [[ "$verb" == "check" ]]; then header="igniter env check — required machine-mode env from $cat (values never read):"
  else header="igniter env doctor — required machine-mode env from $cat (values never read):"; fi
  echo "$header"
  for row in "${rows[@]}"; do
    IFS='|' read -r sec key name <<<"$row"
    local status
    if [[ -z "${!name+x}" ]]; then status="unset"; missing=$((missing+1))
    elif [[ -z "${!name}" ]]; then status="empty"; missing=$((missing+1))
    else status="set"; fi
    printf '  [%-5s] %s  (%s%s)\n' "$status" "$name" "${sec:+[$sec].}" "$key"
  done

  if [[ "$verb" == "check" ]]; then
    if [[ "$missing" -gt 0 ]]; then
      echo "igniter env check: FAIL — $missing required env var(s) unset/empty (export them, never commit values)" >&2
      exit 1
    fi
    echo "igniter env check: ok — all required env vars are set"
    exit 0
  fi
  exit 0   # doctor: a report, not a gate
}

# ── dispatch ──────────────────────────────────────────────────────────────────────────────────────

main() {
  local sub="${1:-}"
  case "$sub" in
    ""|-h|--help|help) usage; exit 0 ;;
    serve)     shift; cmd_serve "$@" ;;
    check)     shift; cmd_check "$@" ;;
    doctor)    shift; cmd_doctor "$@" ;;
    toolchain) shift; cmd_toolchain "$@" ;;
    package)   shift; cmd_package "$@" ;;
    app)       shift; cmd_app "$@" ;;
    agent)     shift; cmd_agent "$@" ;;
    env)       shift; cmd_env "$@" ;;
    stdlib)    shift; cmd_stdlib "$@" ;;
    explain)   shift; cmd_explain "$@" ;;
    *)
      echo "$PROG: unknown command '$sub'" >&2
      echo >&2
      usage >&2
      exit 2 ;;
  esac
}

main "$@"
