{
  "capability_id": "cap-http-client-api-example",
  "resource_type": "network",
  "protocol": "tcp",
  "direction": "connect",
  "bind_address": null,
  "allowed_hosts": ["api.example.com"],
  "allowed_port_ranges": [{ "min": 443, "max": 443 }],
  "loopback_only": false,
  "connect_allowed": true,
  "listen_allowed": false,
  "send_allowed": true,
  "receive_allowed": true,
  "tls_required": true,
  "http_policy": {
    "allowed_methods": ["GET", "POST"],
    "timeout_budget_ms": 5000,
    "max_redirects": 0,
    "policy_source": "lab-http-client-policy-v0"
  }
}
