{
  "view_id": "igniter.lab.nested_slots_dashboard",
  "canvas": {
    "width": 1024,
    "height": 768
  },
  "slots": {
    "widget_1.sidebar.tab": {
      "type": "string"
    }
  },
  "nodes": [
    {
      "id": "root",
      "type": "container",
      "style": { "width": 1024, "height": 768 }
    },
    {
      "id": "nested_tab_node",
      "type": "rect",
      "parent": "root",
      "style": { "width": 100, "height": 100 },
      "display_rules": [
        ["style", ["eq", ["slot", "widget_1.sidebar.tab"], "overview"], { "fill": "#00ff00" }, { "fill": "#ff0000" }]
      ]
    }
  ],
  "non_claims": [
    "lab-only",
    "experimental",
    "no-canon",
    "no-stable-schema",
    "no-performance-claim"
  ]
}
