{
  "site_id": "igniter-org-v0",
  "locales": ["en", "ru", "uk"],
  "default_locale": "en",
  "canonical_url_policy": {
    "rule": "translated_canonical_to_self__fallback_canonical_to_default_locale",
    "default_locale": "en",
    "description": "If a page is translated and active, canonical points to self. If a page is an untranslated fallback, canonical points to the default-locale path."
  },
  "hreflang_policy": {
    "emit_x_default": true,
    "x_default_locale": "en",
    "only_emit_for_existing_equivalents": true,
    "description": "Emit hreflang alternate links for every locale that has an equivalent page. x-default points to the default locale path. Do not emit hreflang for locales where no equivalent exists."
  },
  "generated_output_policy": {
    "output_root": "dist/",
    "pattern": "<locale>/<surface>/<slug>/index.html",
    "root_pattern": "index.html",
    "locale_root_pattern": "<locale>/index.html",
    "note": "Output paths are separate from source content paths. Source lives under content/. Output lives under dist/. No overlap."
  },
  "source_content_refs": {
    "home": "content/tutorial/en/home.md",
    "language": "en/language.html",
